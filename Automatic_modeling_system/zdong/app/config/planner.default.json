{
  "version": "planner.2026-03-31",
  "strategies": {
    "text_to_massing": {
      "regeneration_scope": "building",
      "strategy_reason": "Text-only request without drawing-driven geometry input.",
      "explainability_notes": "纯文本请求遵循 Intake → Intent → Rule Engine → BIM 的链路以形成可追溯的体量方案。",
      "affected_modules": [
        "ai_intent",
        "rule_engine",
        "bim_engine",
        "validation_export"
      ],
      "steps": [
        {
          "name": "normalize_inputs",
          "module": "intake",
          "description": "归档文本和表单输入，生成 SourceBundle。",
          "inputs": [
            "ModelingRequestInput"
          ],
          "outputs": [
            "SourceBundle"
          ]
        },
        {
          "name": "transform_intent",
          "module": "ai_intent",
          "description": "按结构化 schema 生成 DesignIntent。",
          "inputs": [
            "SourceBundle",
            "ParsedDrawingModel"
          ],
          "outputs": [
            "StructuredIntentOutput",
            "DesignIntent"
          ]
        },
        {
          "name": "evaluate_rules",
          "module": "rule_engine",
          "description": "执行配置化规则校验并生成 solver 约束。",
          "inputs": [
            "DesignIntent",
            "ParsedDrawingModel"
          ],
          "outputs": [
            "RuleCheckResult"
          ]
        },
        {
          "name": "build_bim",
          "module": "bim_engine",
          "description": "生成方案级语义 BIM 模型。",
          "inputs": [
            "DesignIntent",
            "RuleCheckResult"
          ],
          "outputs": [
            "BimSemanticModel"
          ]
        },
        {
          "name": "validate_and_export",
          "module": "validation_export",
          "description": "执行自检并导出 IFC/JSON 产物。",
          "inputs": [
            "BimSemanticModel",
            "DesignIntent",
            "RuleCheckResult"
          ],
          "outputs": [
            "ValidationReport",
            "ExportBundle"
          ]
        }
      ]
    },
